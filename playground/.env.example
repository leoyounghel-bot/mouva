# Mouva Frontend Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# AI PROVIDER (Required for AI generation)
# ============================================
TOGETHER_API_KEY=your_together_api_key

# ============================================
# AUTHENTICATION (Required for login)
# ============================================
# Google OAuth - get from Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================
# BACKEND API (Required for auth, sessions)
# ============================================
# Local development
VITE_API_URL=http://localhost:5800/api
# Production
# VITE_API_URL=https://your-api-domain.com/api
